# Stellar testnet endpoints
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
# Funded testnet sponsor secret (S...). Mirrors the facilitator's STELLAR_SPONSOR_SECRET_TESTNET.
# Pays the Wasm install + contract deploy + invocation fee. Node-only; never in any SDK package.
SPONSOR_SECRET=Sxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# USDC SAC contract id on testnet (matches facilitator STELLAR_USDC_TESTNET_SAC)
USDC_SAC=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
# Optional: a G-account that holds testnet USDC to fund the new C-address via the SAC
# (a contract account has no classic trustline). Falls back to SPONSOR_SECRET if unset.
USDC_FUNDER_SECRET=Sxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# A funded testnet G-address to receive the USDC transfer.
RECIPIENT_PUBLIC_KEY=Gxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The minimal passkey smart-account wasm (prebuilt + committed under ./wasm). Verified before install.
OZ_SMART_ACCOUNT_WASM_PATH=./wasm/minimal_passkey_account.wasm
# Optional: pin the installed Wasm hash to skip install. Canonical hash for the committed wasm:
OZ_SMART_ACCOUNT_WASM_HASH=bf1aa9b2a4f8c05e1e5226009800bf69bd9ab7375ad160a1113d8d31a6ffdc69
