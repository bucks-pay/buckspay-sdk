{
  "name": "buckspay-sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "e2e": "pnpm --filter @buckspay/e2e test:e2e",
    "e2e:web": "pnpm --filter @buckspay/e2e test:web",
    "docs:dev": "cd docs && npx mintlify@4.2.649 dev",
    "docs:sync": "node scripts/sync-doc-snippets.mjs",
    "docs:check": "node scripts/check-doc-snippets.mjs",
    "docs:typecheck": "pnpm --filter @buckspay/docs-examples typecheck",
    "docs:links": "find docs -name '*.mdx' -not -path '*/node_modules/*' | xargs markdown-link-check -q -c .markdown-link-check.json",
    "docs:api": "typedoc && node scripts/postprocess-sdk-reference.mjs",
    "audit": "pnpm audit --audit-level=high --prod",
    "licenses": "node scripts/check-licenses.mjs",
    "verify:wasm": "node scripts/verify-wasm-hash.mjs",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "markdown-link-check": "^3.13.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.3.0",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
