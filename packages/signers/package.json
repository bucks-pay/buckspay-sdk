{
  "name": "@buckspay/signers",
  "version": "0.1.3",
  "type": "module",
  "license": "MIT",
  "description": "Buckspay SDK signers: Stellar Wallets Kit (Freighter/xBull/LOBSTR) BuckspaySigner for gasless Soroban auth-entry signing.",
  "keywords": [
    "stellar",
    "soroban",
    "wallets-kit",
    "freighter",
    "gasless",
    "account-abstraction",
    "usdc",
    "web3",
    "sdk"
  ],
  "homepage": "https://github.com/bucks-pay/buckspay-sdk/tree/main/packages/signers#readme",
  "bugs": "https://github.com/bucks-pay/buckspay-sdk/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bucks-pay/buckspay-sdk.git",
    "directory": "packages/signers"
  },
  "author": "Buckspay",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./wallets-kit": {
      "types": "./dist/wallets-kit/index.d.ts",
      "import": "./dist/wallets-kit/index.js",
      "require": "./dist/wallets-kit/index.cjs"
    },
    "./passkey": {
      "types": "./dist/passkey/index.d.ts",
      "import": "./dist/passkey/index.js",
      "require": "./dist/passkey/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "wallets-kit": [
        "./dist/wallets-kit/index.d.ts"
      ],
      "passkey": [
        "./dist/passkey/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@buckspay/core": "workspace:^",
    "@creit.tech/stellar-wallets-kit": "^1.7.0",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@stellar/stellar-sdk": "^14.6.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
