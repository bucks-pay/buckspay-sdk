{
  "name": "@buckspay/nextjs",
  "version": "0.2.1",
  "type": "module",
  "license": "MIT",
  "description": "Next.js (App Router) server helpers for the Buckspay SDK: BFF relay proxy + social/email signer-proxy route handlers for gasless Stellar (Soroban) USDC payments.",
  "keywords": [
    "stellar",
    "soroban",
    "nextjs",
    "bff",
    "gasless",
    "account-abstraction",
    "usdc",
    "smart-wallet",
    "web3",
    "sdk"
  ],
  "homepage": "https://github.com/bucks-pay/buckspay-sdk/tree/main/packages/nextjs#readme",
  "bugs": "https://github.com/bucks-pay/buckspay-sdk/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bucks-pay/buckspay-sdk.git",
    "directory": "packages/nextjs"
  },
  "author": "Buckspay",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@buckspay/core": "workspace:^",
    "@buckspay/relayer": "workspace:^",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
