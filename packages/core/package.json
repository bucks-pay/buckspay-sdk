{
  "name": "@buckspay/core",
  "version": "0.2.2",
  "type": "module",
  "license": "MIT",
  "description": "Framework-agnostic core of the Buckspay SDK: gas-abstraction engine, prepare/sign/send client, and the typed account/signer/relayer ports for gasless Stellar (Soroban) USDC payments.",
  "keywords": [
    "stellar",
    "soroban",
    "gas-abstraction",
    "account-abstraction",
    "usdc",
    "gasless",
    "smart-wallet",
    "passkey",
    "web3",
    "sdk"
  ],
  "homepage": "https://github.com/bucks-pay/buckspay-sdk/tree/main/packages/core#readme",
  "bugs": "https://github.com/bucks-pay/buckspay-sdk/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bucks-pay/buckspay-sdk.git",
    "directory": "packages/core"
  },
  "author": "Buckspay",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.6.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
