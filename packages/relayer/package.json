{
  "name": "@buckspay/relayer",
  "version": "0.1.3",
  "type": "module",
  "license": "MIT",
  "description": "Buckspay SDK relayer: a typed, zod-validated client for the Buckspay facilitator (relay, account state, sponsored onboarding) for gasless Stellar USDC.",
  "keywords": [
    "stellar",
    "soroban",
    "facilitator",
    "relayer",
    "paymaster",
    "gasless",
    "usdc",
    "x402",
    "web3",
    "sdk"
  ],
  "homepage": "https://github.com/bucks-pay/buckspay-sdk/tree/main/packages/relayer#readme",
  "bugs": "https://github.com/bucks-pay/buckspay-sdk/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bucks-pay/buckspay-sdk.git",
    "directory": "packages/relayer"
  },
  "author": "Buckspay",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./buckspay-facilitator": {
      "types": "./dist/buckspay-facilitator/index.d.ts",
      "import": "./dist/buckspay-facilitator/index.js",
      "require": "./dist/buckspay-facilitator/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "buckspay-facilitator": [
        "./dist/buckspay-facilitator/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@buckspay/core": "workspace:^",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
