{
  "name": "@buckspay/react",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "React 19 hooks for the Buckspay SDK: BuckspayProvider, useWallet, useStellarPay for gasless Stellar (Soroban) USDC payments.",
  "keywords": [
    "stellar",
    "soroban",
    "react",
    "hooks",
    "gasless",
    "account-abstraction",
    "usdc",
    "smart-wallet",
    "web3",
    "sdk"
  ],
  "homepage": "https://github.com/bucks-pay/buckspay-sdk/tree/main/packages/react#readme",
  "bugs": "https://github.com/bucks-pay/buckspay-sdk/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bucks-pay/buckspay-sdk.git",
    "directory": "packages/react"
  },
  "author": "Buckspay",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@buckspay/core": "workspace:^",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
