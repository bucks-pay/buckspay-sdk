{
  "name": "@buckspay/accounts",
  "version": "0.1.4",
  "type": "module",
  "license": "MIT",
  "description": "Buckspay SDK account adapters: classic (G-address) Stellar account model for gasless USDC transfers, with sponsored onboarding via a facilitator.",
  "keywords": [
    "stellar",
    "soroban",
    "account-abstraction",
    "smart-wallet",
    "gasless",
    "usdc",
    "onboarding",
    "web3",
    "sdk"
  ],
  "homepage": "https://github.com/bucks-pay/buckspay-sdk/tree/main/packages/accounts#readme",
  "bugs": "https://github.com/bucks-pay/buckspay-sdk/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bucks-pay/buckspay-sdk.git",
    "directory": "packages/accounts"
  },
  "author": "Buckspay",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./classic": {
      "types": "./dist/classic/index.d.ts",
      "import": "./dist/classic/index.js",
      "require": "./dist/classic/index.cjs"
    },
    "./oz-contract": {
      "types": "./dist/oz-contract/index.d.ts",
      "import": "./dist/oz-contract/index.js",
      "require": "./dist/oz-contract/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "classic": [
        "./dist/classic/index.d.ts"
      ],
      "oz-contract": [
        "./dist/oz-contract/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@buckspay/core": "workspace:^",
    "@stellar/stellar-sdk": "^14.6.1"
  },
  "devDependencies": {
    "@buckspay/signers": "workspace:^",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
